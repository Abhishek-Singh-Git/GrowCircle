# GrowCircle Backend — Environment Configuration Example

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/growcircle"

# JWT
JWT_SECRET="replace-me-with-a-secure-secret"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="30d"

# Google OAuth
GOOGLE_CLIENT_ID_WEB="your-web-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_ID_ANDROID="your-android-client-id.apps.googleusercontent.com"

# Firebase (FCM)
# Required for push notifications. Provide the full JSON string representation.
FIREBASE_ADMIN_SDK='{"type":"service_account", "project_id": "...", ...}'

# App
PORT=3001
NODE_ENV="development"
